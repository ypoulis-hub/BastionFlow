<Window x:Class="BastionFlow.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:BastionFlow.App.Converters"
        Title="BastionFlow"
        Icon="{StaticResource AppLogo}"
        Width="1080" Height="680"
        MinWidth="780" MinHeight="500"
        Background="{StaticResource Bg}"
        Foreground="{StaticResource Fg}"
        FontFamily="{StaticResource FontUI}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>
        <conv:NullToVisibilityConverter x:Key="NotNullToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis" Invert="True"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== Hero header ===== -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1">
            <Grid Margin="24,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + wordmark -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{StaticResource AppLogo}" Width="36" Height="36"/>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="BastionFlow"
                                   FontFamily="{StaticResource FontDisplay}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg}"/>
                        <TextBlock Text="Admin RDP via Azure Bastion"
                                   FontSize="11"
                                   Foreground="{StaticResource FgMuted}"
                                   Margin="0,-1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right cluster: account info (signed in) + About (always visible) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,12,0" HorizontalAlignment="Right"
                                Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Account}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource FgMuted}" HorizontalAlignment="Right">
                            <Run Text="{Binding ResolvedCount, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding VmCount, Mode=OneWay}"/>
                            <Run Text=" resolved"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Content="Sign out"
                            Style="{StaticResource GhostButton}"
                            Margin="0,0,8,0"
                            Command="{Binding SignOutCommand}"
                            Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="About"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ShowAboutCommand}"
                            ToolTip="About BastionFlow"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="1" Background="{StaticResource Bg}" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Sign in -->
                <Button Grid.Column="0"
                        Content="Sign in"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SignInCommand}"
                        Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVisInv}}"/>

                <!-- Refresh -->
                <Button Grid.Column="0"
                        Content="↻  Refresh"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding RefreshCommand}"
                        Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVis}}"/>

                <!-- Search box (TextBox + overlaid placeholder, both in the same cell) -->
                <Grid Grid.Column="4"
                      MaxWidth="420"
                      HorizontalAlignment="Stretch"
                      Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVis}}">
                    <TextBox x:Name="FilterTextBox"
                             Style="{StaticResource SearchBox}"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filter by VM name, resource group, AAD device, or host pool"/>
                    <TextBlock Text="🔍   Filter VMs, RGs, AAD device names, host pools..."
                               Foreground="{StaticResource FgFaint}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="14,0,12,0"
                               IsHitTestVisible="False"
                               Visibility="{Binding FilterText, Converter={StaticResource NullToVis}}"/>
                </Grid>

                <!-- Busy indicator -->
                <TextBlock Grid.Column="5"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource FgMuted}"
                           FontSize="12"
                           Text="working..."
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

        <!-- ===== Main content ===== -->
        <Grid Grid.Row="2" Margin="24,0,24,16">
            <!-- Empty state when not signed in -->
            <Border Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVisInv}}"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" MaxWidth="460">
                    <Image Source="{StaticResource AppLogo}" Width="80" Height="80" Opacity="0.6" HorizontalAlignment="Center"/>
                    <TextBlock Text="Sign in to your Azure tenant"
                               FontFamily="{StaticResource FontDisplay}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Fg}"
                               HorizontalAlignment="Center"
                               Margin="0,18,0,6"/>
                    <TextBlock TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{StaticResource FgMuted}"
                               FontSize="13"
                               Text="BastionFlow discovers every Windows VM you can reach, resolves the matching Entra device name, and launches an AAD-RDP session through Azure Bastion — no PowerShell required."/>
                </StackPanel>
            </Border>

            <!-- VM list (signed in) -->
            <DockPanel Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVis}}">
                <!-- 293004 fallback banner -->
                <Border DockPanel.Dock="Top"
                        Background="#3A2814"
                        BorderBrush="{StaticResource Warning}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,10"
                        Visibility="{Binding ShowFallbackBanner, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚠" Foreground="{StaticResource Warning}" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding FallbackBannerText}" Foreground="{StaticResource Fg}" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="13"/>
                        <Button Grid.Column="2" Content="Retry with local admin" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                Command="{Binding RetryWithLocalAdminCommand}"/>
                        <Button Grid.Column="3" Content="Dismiss" Style="{StaticResource GhostButton}"
                                Command="{Binding DismissFallbackCommand}"/>
                    </Grid>
                </Border>

                <Border Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="8">
                <DataGrid Style="{StaticResource VmGrid}"
                          ItemsSource="{Binding VmsView}">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <!-- Stash the MainViewModel on Tag so the ContextMenu (in a separate
                                 visual tree) can reach our commands via PlacementTarget.Tag. -->
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Connect (AAD-RDP)"
                                                  Command="{Binding PlacementTarget.Tag.ConnectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Connect (local admin / CredSSP)"
                                                  Command="{Binding PlacementTarget.Tag.ConnectLocalAdminCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <!-- Status indicator -->
                        <DataGridTemplateColumn Header="" Width="46">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="10" Height="10" CornerRadius="5" Margin="14,0,0,0"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource Warning}"/>
                                                <Setter Property="ToolTip" Value="AAD device not resolved — Connect will probe via run-command (~30s)"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AadDeviceName, Converter={StaticResource NotNullToVis}}" Value="Visible">
                                                        <Setter Property="Background" Value="{StaticResource Success}"/>
                                                        <Setter Property="ToolTip" Value="AAD device resolved — ready to connect"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="VM" Binding="{Binding Name}" Width="200"/>
                        <DataGridTextColumn Header="Resource group" Binding="{Binding ResourceGroup}" Width="240"/>

                        <!-- Power state with subtle color -->
                        <DataGridTemplateColumn Header="Power" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PowerState}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="AAD device" Binding="{Binding AadDeviceName}" Width="220">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AadDeviceName, Converter={StaticResource NotNullToVis}}" Value="Visible">
                                            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="AVD host pool" Binding="{Binding AvdHostPool}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Connect"
                                            Style="{StaticResource RowConnectButton}"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,12,0"
                                            ToolTip="Connect via AAD-RDP. Right-click the row for local-admin fallback."
                                            Command="{Binding DataContext.ConnectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                </Border>
            </DockPanel>
        </Grid>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="3" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0" Height="36">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource FgMuted}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           ToolTip="{Binding StatusDetail}"
                           ToolTipService.ShowDuration="60000"/>
                <TextBlock Grid.Column="1"
                           Text="v0.1-alpha · MIT"
                           Foreground="{StaticResource FgFaint}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
