<Window x:Class="BastionFlow.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About BastionFlow"
        Width="460" Height="540"
        Icon="{StaticResource AppLogo}"
        Background="{StaticResource Bg}"
        Foreground="{StaticResource Fg}"
        FontFamily="{StaticResource FontUI}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hero: logo + wordmark -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <Image Source="{StaticResource AppLogo}" Width="80" Height="80"/>
            <TextBlock Text="BastionFlow"
                       FontFamily="{StaticResource FontDisplay}"
                       FontSize="28"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource Fg}"
                       Margin="0,16,0,2"/>
            <TextBlock Text="Admin RDP via Azure Bastion"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource FgMuted}"/>
            <TextBlock x:Name="VersionText"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource FgFaint}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   Text="Discover every Windows VM in your tenant, resolve the matching Entra device name, and launch an AAD-RDP session through Azure Bastion. No PowerShell required."
                   FontSize="12"
                   Foreground="{StaticResource FgMuted}"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="20,22,20,0"/>

        <!-- Credit -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18,14"
                Margin="0,22,0,0">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Built by" Foreground="{StaticResource FgMuted}" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="JohnBird" Foreground="{StaticResource Fg}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Border Background="{StaticResource BorderSubtle}" Height="1" Margin="0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="License" Foreground="{StaticResource FgMuted}" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="MIT" Foreground="{StaticResource Fg}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Border Background="{StaticResource BorderSubtle}" Height="1" Margin="0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Copyright" Foreground="{StaticResource FgMuted}" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="© 2026 JohnBird" Foreground="{StaticResource Fg}" FontSize="13"/>
                </Grid>
                <Border Background="{StaticResource BorderSubtle}" Height="1" Margin="0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource FgMuted}" FontSize="12" Text="Support development"/>
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13">
                        <Hyperlink NavigateUri="https://www.paypal.com/donate/?business=ypoulis@gmail.com&amp;item_name=BastionFlow&amp;currency_code=EUR"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#0070BA"
                                   TextDecorations="Underline">
                            Donate via PayPal
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </Border>

        <!-- License preamble (scrollable, in case user wants to read it inline) -->
        <Border Grid.Row="3"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,12"
                Margin="0,16,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock TextWrapping="Wrap"
                           FontFamily="{StaticResource FontMono}"
                           FontSize="10"
                           Foreground="{StaticResource FgMuted}">
                    <Run Text="Permission is hereby granted, free of charge, to any person obtaining a copy of this software and associated documentation files (the “Software”), to deal in the Software without restriction, including without limitation the rights to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the Software, and to permit persons to whom the Software is furnished to do so, subject to the following conditions:"/>
                    <LineBreak/><LineBreak/>
                    <Run Text="The above copyright notice and this permission notice shall be included in all copies or substantial portions of the Software."/>
                    <LineBreak/><LineBreak/>
                    <Run Text="THE SOFTWARE IS PROVIDED “AS IS”, WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE."/>
                </TextBlock>
            </ScrollViewer>
        </Border>

        <!-- Close -->
        <Button Grid.Row="4"
                Content="Close"
                Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right"
                Margin="0,18,0,0"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
